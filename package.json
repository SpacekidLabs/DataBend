{
  "name": "databend",
  "version": "1.1.0",
  "description": "An experimental Electron audio editor for glitch, slicing, and spectral processing.",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "keywords": [
    "audio",
    "electron",
    "glitch",
    "editor",
    "waveform",
    "wavelet",
    "databend",
    "dsp"
  ],
  "author": "DATABEND Lab",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git@github.com:SpacekidLabs/DataBend.git"
  },
  "bugs": {
    "url": "https://github.com/SpacekidLabs/DataBend/issues"
  },
  "homepage": "https://github.com/SpacekidLabs/DataBend#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.databend.app",
    "productName": "DATABEND",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "app.js",
      "spectralWorker.js",
      "kmeansWorker.js",
      "styles.css",
      "main.js",
      "preload.js",
      "splash.html",
      "splash-preload.js",
      "splash-logo.png",
      "build/icon.png"
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "Install DATABEND",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    }
  }
}
